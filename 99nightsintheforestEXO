-- ╔══════════════════════════════════════╗
--   AUTO CUT TREES
--   Uses tool swing on SMALL trees only
--   Old Axe CANNOT cut big trees
--   so we skip anything too large
-- ╚══════════════════════════════════════╝

local SMALL_TREE_MAX_SIZE = 8  -- studs — anything bigger is a big tree, skip it
local CUT_COOLDOWN = 0.4       -- seconds between swings

local function isSmallTree(obj)
    -- Only cut small/young trees the Old Axe can handle
    local name = obj.Name:lower()
    if not (name:find("tree") or name:find("sapling") or name:find("bush") or name:find("shrub") or name:find("small")) then
        return false
    end
    local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
    if not part then return false end
    -- Check physical size — big trees have tall/wide parts
    if part.Size.Y > SMALL_TREE_MAX_SIZE or part.Size.X > SMALL_TREE_MAX_SIZE then
        return false
    end
    return true
end

local function findNearestSmallTree(hrp)
    local nearest, nearestDist = nil, math.huge
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and isSmallTree(obj) then
            local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
            if part then
                local d = (part.Position - hrp.Position).Magnitude
                if d < nearestDist then nearest = obj; nearestDist = d end
            end
        end
    end
    return nearest, nearestDist
end

local function swingTool()
    -- Equip and swing whatever tool is in hotbar
    local char = player.Character; if not char then return end
    local tool = char:FindFirstChildOfClass("Tool")
    if not tool then
        -- Try equipping from backpack
        local bp = player.Backpack
        if bp then
            local t = bp:FindFirstChildOfClass("Tool")
            if t then
                player.Character.Humanoid:EquipTool(t)
                task.wait(0.1)
                tool = char:FindFirstChildOfClass("Tool")
            end
        end
    end
    if tool then
        pcall(function() tool:Activate() end)
        -- Also fire any chop remotes inside the tool
        for _, v in ipairs(tool:GetDescendants()) do
            if v:IsA("RemoteEvent") then
                local n = v.Name:lower()
                if n:find("chop") or n:find("cut") or n:find("hit") or n:find("swing") then
                    pcall(function() v:FireServer() end)
                end
            end
        end
    end
    -- Also check workspace/RS for chop remotes
    pcall(function()
        for _, v in ipairs(game:GetDescendants()) do
            if v:IsA("RemoteEvent") then
                local n = v.Name:lower()
                if n:find("choptree") or n:find("cuttree") or n:find("harvesttree") or n:find("chopwood") then
                    v:FireServer()
                end
            end
        end
    end)
end

local lastCut = 0
local function startAutoCut()
    autoCutConn = RunService.Heartbeat:Connect(function()
        if not states.autoCutTree then return end
        local now = tick(); if now - lastCut < CUT_COOLDOWN then return end
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart"); if not hrp then return end
        local tree, dist = findNearestSmallTree(hrp)
        if not tree then return end
        local part = tree.PrimaryPart or tree:FindFirstChildWhichIsA("BasePart")
        if part then
            -- Walk right up to it
            if dist > 4 then
                hrp.CFrame = CFrame.new(part.Position + Vector3.new(2, 0, 0))
                task.wait(0.05)
            end
            swingTool()
            lastCut = tick()
        end
    end)
end
local function stopAutoCut() if autoCutConn then autoCutConn:Disconnect(); autoCutConn = nil end end

-- ╔══════════════════════════════════════╗
--   AUTO COLLECT
--   Teleports to and touches dropped items
-- ╚══════════════════════════════════════╝

local COLLECT_KEYWORDS = {
    "woodlog", "log", "wood", "stone", "rock", "berry", "fruit",
    "item", "drop", "pickup", "loot", "resource", "material",
    "food", "meat", "fiber", "rope", "plank", "branch", "stick",
}

local function isCollectible(obj)
    local name = obj.Name:lower()
    for _, kw in ipairs(COLLECT_KEYWORDS) do
        if name:find(kw) then return true end
    end
    return false
end

local lastCollect = 0
local function startAutoCollect()
    autoCollConn = RunService.Heartbeat:Connect(function()
        if not states.autoCollect then return end
        local now = tick(); if now - lastCollect < 0.2 then return end
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart"); if not hrp then return end
        for _, obj in ipairs(workspace:GetDescendants()) do
            if (obj:IsA("BasePart") or obj:IsA("Model")) and isCollectible(obj) then
                local part = obj:IsA("BasePart") and obj or obj:FindFirstChildWhichIsA("BasePart")
                if part then
                    local dist = (part.Position - hrp.Position).Magnitude
                    if dist < 80 then
                        -- Teleport on top of it to trigger pickup proximity
                        hrp.CFrame = CFrame.new(part.Position + Vector3.new(0, 2, 0))
                        -- Fire any pickup remotes
                        pcall(function()
                            for _, v in ipairs(game:GetDescendants()) do
                                if v:IsA("RemoteEvent") then
                                    local n = v.Name:lower()
                                    if n:find("pickup") or n:find("collect") or n:find("grab") or n:find("take") or n:find("loot") then
                                        v:FireServer(obj)
                                        v:FireServer(part)
                                    end
                                end
                            end
                        end)
                        lastCollect = tick()
                        task.wait(0.15)
                        break -- One at a time
                    end
                end
            end
        end
    end)
end
local function stopAutoCollect() if autoCollConn then autoCollConn:Disconnect(); autoCollConn = nil end end

-- ╔══════════════════════════════════════╗
--   AUTO BRING
--   Physically moves dropped items to you
--   Works by setting CFrame of loose parts
-- ╚══════════════════════════════════════╝

local function startAutoBring()
    autoBringConn = RunService.Heartbeat:Connect(function()
        if not states.autoBring then return end
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart"); if not hrp then return end
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and isCollectible(obj) then
                local dist = (obj.Position - hrp.Position).Magnitude
                if dist < 100 and dist > 2 then
                    pcall(function()
                        obj.Anchored = false
                        obj.CFrame = hrp.CFrame * CFrame.new(math.random(-2,2), 0, math.random(-2,2))
                    end)
                end
            elseif obj:IsA("Model") and isCollectible(obj) then
                local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                if part then
                    local dist = (part.Position - hrp.Position).Magnitude
                    if dist < 100 and dist > 2 then
                        pcall(function()
                            obj:SetPrimaryPartCFrame(hrp.CFrame * CFrame.new(math.random(-2,2), 0, math.random(-2,2)))
                        end)
                    end
                end
            end
        end
        task.wait(0.1)
    end)
end
local function stopAutoBring() if autoBringConn then autoBringConn:Disconnect(); autoBringConn = nil end end

local function startAutoCraft()
    task.spawn(function()
        while states.autoCraft do
            pcall(function()
                for _, v in ipairs(game:GetDescendants()) do
                    if v:IsA("RemoteEvent") then
                        local n=v.Name:lower()
                        if n:find("craft") or n:find("build") or n:find("make") then v:FireServer() end
                    end
                end
                for _, gui in ipairs(player.PlayerGui:GetDescendants()) do
                    if (gui:IsA("TextButton") or gui:IsA("ImageButton")) then
                        local n=gui.Name:lower()
                        if n:find("craft") or n:find("build") then gui.MouseButton1Click:Fire() end
                    end
                end
            end)
            task.wait(1)
        end
    end)
end

